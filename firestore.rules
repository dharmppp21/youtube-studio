rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Default Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definitions & Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validation functions
    function isValidChannel(data) {
      return data.keys().hasAll(['id', 'name', 'handle', 'subscribers', 'views', 'watchTime', 'revenue', 'createdAt'])
        && data.keys().size() <= 12
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.handle is string && data.handle.size() > 0 && data.handle.size() <= 50
        && data.subscribers is number && data.subscribers >= 0
        && data.views is number && data.views >= 0
        && data.watchTime is number && data.watchTime >= 0
        && data.revenue is number && data.revenue >= 0;
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['id', 'ownerId', 'title', 'visibility', 'views', 'likes', 'commentsCount', 'createdAt'])
        && data.keys().size() <= 18
        && data.id is string && data.id.size() <= 128
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 150
        && data.visibility is string && (data.visibility == 'public' || data.visibility == 'unlisted' || data.visibility == 'private')
        && data.views is number && data.views >= 0
        && data.likes is number && data.likes >= 0
        && data.commentsCount is number && data.commentsCount >= 0;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['id', 'videoId', 'ownerId', 'authorName', 'content', 'likes', 'hasHeart', 'isPinned', 'createdAt'])
        && data.keys().size() <= 14
        && data.id is string && data.id.size() <= 128
        && data.videoId is string && data.videoId.size() <= 128
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 200
        && data.content is string && data.content.size() > 0 && data.content.size() <= 10000
        && data.likes is number && data.likes >= 0
        && data.hasHeart is bool
        && data.isPinned is bool;
    }

    function isValidAnalyticsSnapshot(data) {
      return data.keys().hasAll(['id', 'ownerId', 'date', 'views', 'watchTime', 'revenue', 'subscribers'])
        && data.keys().size() <= 8
        && data.id is string && data.id.size() <= 128
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.date is string && data.date.size() <= 15
        && data.views is number && data.views >= 0
        && data.watchTime is number && data.watchTime >= 0
        && data.revenue is number && data.revenue >= 0
        && data.subscribers is number;
    }

    // 4. Fortress Rules for Collections

    // Channels Collection
    match /channels/{channelId} {
      allow get: if isSignedIn(); // Let logged-in users see channel details
      allow list: if isSignedIn() && resource.data.id == request.auth.uid; // Only list own channels
      allow create: if isSignedIn() && channelId == request.auth.uid && isValidChannel(request.resource.data) && request.resource.data.id == request.auth.uid;
      allow update: if isSignedIn() && channelId == request.auth.uid && isValidChannel(request.resource.data) && request.resource.data.id == request.auth.uid;
      allow delete: if isSignedIn() && channelId == request.auth.uid;
    }

    // Videos Collection
    match /videos/{videoId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid; // Secure list query enforcer
      allow create: if isSignedIn() && isValidVideo(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && isValidVideo(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Comments Collection
    match /comments/{commentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid; // Secure list query enforcer
      allow create: if isSignedIn() && isValidComment(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && isValidComment(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Analytics Snapshots Collection
    match /analytics/{snapshotId} {
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid; // Secure list query enforcer
      allow create: if isSignedIn() && isValidAnalyticsSnapshot(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && isValidAnalyticsSnapshot(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
