# Production environment for the YouTube Creator Studio applet.
#
# Copy this file to `.env` on the VPS and fill in real values:
#     cp deploy/env.production.example .env
#     nano .env
#
# `.env` is git-ignored — never commit it.

# Required. Server reads this on every request and will throw if missing.
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace_me_with_your_gemini_api_key

# Public URL the applet is served on. Used for self-referential links and
# OAuth callback hints (Firebase Auth uses the project's authorized domains,
# not this value, but having it set keeps logs clean).
APP_URL=http://YOUR_VPS_IP

# Standard Node production flag.
NODE_ENV=production

# Port the Express server binds to. Defaults to 3000 if unset.
# nginx proxies localhost:3000 <-> the public internet.
PORT=3000